<Window x:Class="WpfMaterialControls.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ввод"
        Width="480"
        Height="240"
        MinWidth="480"
        MinHeight="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8F8FA">
    <Grid Margin="16">
        <Border Background="White"
                BorderBrush="#ECECF3"
                BorderThickness="1"
                CornerRadius="16"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="LabelText"
                           Grid.Row="0"
                           Text="Введите значение"
                           FontSize="14"
                           Foreground="#2A2F39"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10" />

                <TextBox x:Name="InputBox"
                         Grid.Row="1"
                         Padding="10,8"
                         FontSize="14"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         BorderBrush="#D7DAE5"
                         BorderThickness="1" />

                <TextBlock x:Name="HintText"
                           Grid.Row="2"
                           Text=""
                           Foreground="#8A90A0"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap" />

                <Border Grid.Row="3"
                        Margin="0,10,0,0"
                        Padding="10"
                        CornerRadius="10"
                        Background="#FDECEE"
                        Visibility="{Binding ErrorVisibility}">
                    <TextBlock Text="{Binding ErrorText}"
                               Foreground="#D15B75"
                               TextWrapping="Wrap" />
                </Border>

                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0">
                    <Button Width="100"
                            Margin="0,0,10,0"
                            Padding="12,8"
                            IsCancel="True"
                            Content="Отмена" />
                    <Button Width="120"
                            Padding="12,8"
                            Background="#0F1020"
                            Foreground="White"
                            BorderThickness="0"
                            IsDefault="True"
                            IsEnabled="{Binding CanAccept}"
                            Click="Ok_Click"
                            Content="OK" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

