<Window x:Class="WpfMaterialControls.ScooterEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Самокат"
        Width="560"
        Height="560"
        MinWidth="560"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F6F7FA">
    <Window.Resources>
        <SolidColorBrush x:Key="UiTextPrimary" Color="#222222" />
        <SolidColorBrush x:Key="UiTextSecondary" Color="#5D6472" />
        <SolidColorBrush x:Key="UiSurface" Color="White" />
        <SolidColorBrush x:Key="UiInputBg" Color="#F8F9FB" />
        <SolidColorBrush x:Key="UiBorder" Color="#D7DAE5" />
        <SolidColorBrush x:Key="UiError" Color="#D15B75" />
        <SolidColorBrush x:Key="UiHint" Color="#7A1E2B" />

        <Style x:Key="RoundedButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#E9EBF0" />
            <Setter Property="Foreground" Value="{StaticResource UiTextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#DEE2EA" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D3D8E3" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Control}">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip"
                            Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,9" />
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <!-- border is shown on the surrounding Border chrome -->
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,7" />
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <!-- border is shown on the surrounding Border chrome -->
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type DatePicker}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <!-- border is shown on the surrounding Border chrome -->
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <md:Card Padding="26"
                 UniformCornerRadius="18">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Bottom"
                            Margin="0,18,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Width="100"
                            Margin="0,0,10,0"
                            Style="{StaticResource RoundedButtonStyle}"
                            Click="CancelButton_Click"
                            Content="Отмена" />
                    <Button Width="140"
                            Style="{StaticResource RoundedButtonStyle}"
                            Background="#0F1020"
                            Foreground="White"
                            BorderThickness="0"
                            IsEnabled="{Binding CanSave}"
                            Click="SaveButton_Click"
                            Content="Сохранить" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{Binding DialogTitle}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource UiTextPrimary}" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,24,0,8"
                                   Text="Модель"
                                   Foreground="{StaticResource UiTextSecondary}" />
                        <StackPanel Grid.Row="2">
                            <Border Background="{StaticResource UiInputBg}"
                                    BorderBrush="{StaticResource UiBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Border.Style>
                                    <Style TargetType="{x:Type Border}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=txtModel, Path=(Validation.HasError)}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource UiError}" />
                                                <Setter Property="BorderThickness" Value="2" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBox x:Name="txtModel"
                                         Text="{Binding Model, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                            </Border>
                            <TextBlock Margin="2,6,0,0"
                                       Text="{Binding ModelDigitsOnlyHintText}"
                                       Foreground="{StaticResource UiHint}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding ModelDigitsOnlyHintVisibility}" />
                        </StackPanel>

                        <Grid Grid.Row="3" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Margin="0,0,0,8"
                                   Text="Техническое состояние"
                                   Foreground="{StaticResource UiTextSecondary}" />
                        <Border Background="{StaticResource UiInputBg}"
                                BorderBrush="{StaticResource UiBorder}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=cbCondition, Path=(Validation.HasError)}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource UiError}" />
                                            <Setter Property="BorderThickness" Value="2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ComboBox x:Name="cbCondition"
                                      ItemsSource="{Binding Conditions}"
                                      DisplayMemberPath="ConditionName"
                                      SelectedValuePath="ConditionId"
                                      SelectedValue="{Binding SelectedConditionId, ValidatesOnNotifyDataErrors=True}" />
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Margin="0,0,0,8"
                                   Text="Оперативный статус"
                                   Foreground="{StaticResource UiTextSecondary}" />
                        <Border Background="{StaticResource UiInputBg}"
                                BorderBrush="{StaticResource UiBorder}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=cbStatus, Path=(Validation.HasError)}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource UiError}" />
                                            <Setter Property="BorderThickness" Value="2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ComboBox x:Name="cbStatus"
                                      ItemsSource="{Binding AvailableStatuses}"
                                      SelectedItem="{Binding SelectedStatus, ValidatesOnNotifyDataErrors=True}" />
                        </Border>
                    </StackPanel>
                </Grid>

                        <Grid Grid.Row="4" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Margin="0,0,0,8"
                                   Text="Заряд (%)"
                                   Foreground="{StaticResource UiTextSecondary}" />
                        <Border Background="{StaticResource UiInputBg}"
                                BorderBrush="{StaticResource UiBorder}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=txtBattery, Path=(Validation.HasError)}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource UiError}" />
                                            <Setter Property="BorderThickness" Value="2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBox x:Name="txtBattery"
                                     Text="{Binding BatteryPercentText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Margin="0,0,0,8"
                                   Text="Год выпуска"
                                   Foreground="{StaticResource UiTextSecondary}" />
                        <Border Background="{StaticResource UiInputBg}"
                                BorderBrush="{StaticResource UiBorder}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=dpYear, Path=(Validation.HasError)}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource UiError}" />
                                            <Setter Property="BorderThickness" Value="2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <DatePicker x:Name="dpYear"
                                        SelectedDate="{Binding YearOfRelease, ValidatesOnNotifyDataErrors=True}"
                                        IsEnabled="{Binding IsYearOfReleaseEditable}"
                                        SelectedDateFormat="Short" />
                        </Border>
                    </StackPanel>
                </Grid>

                        <TextBlock Grid.Row="5"
                           Margin="0,18,0,8"
                           Text="Местоположение"
                           Foreground="{StaticResource UiTextSecondary}" />
                        <StackPanel Grid.Row="6">
                    <Border Background="{StaticResource UiInputBg}"
                            BorderBrush="{StaticResource UiBorder}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=txtLocation, Path=(Validation.HasError)}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource UiError}" />
                                        <Setter Property="BorderThickness" Value="2" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBox x:Name="txtLocation"
                                 Text="{Binding CurrentLocation, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                    </Border>
                    <TextBlock Margin="2,6,0,0"
                               Text="{Binding LocationDigitsOnlyHintText}"
                               Foreground="{StaticResource UiHint}"
                               FontSize="12.5"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Visibility="{Binding LocationDigitsOnlyHintVisibility}" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </DockPanel>
        </md:Card>
    </Grid>
</Window>
