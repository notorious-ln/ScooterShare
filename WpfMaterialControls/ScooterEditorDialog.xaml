<Window x:Class="WpfMaterialControls.ScooterEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Самокат"
        Width="560"
        Height="560"
        MinWidth="560"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F6F7FA">
    <Window.Resources>
        <Style TargetType="{x:Type Control}">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip"
                            Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="#D15B75" />
                    <Setter Property="BorderThickness" Value="2" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="#D15B75" />
                    <Setter Property="BorderThickness" Value="2" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type DatePicker}">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="#D15B75" />
                    <Setter Property="BorderThickness" Value="2" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <md:Card Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding DialogTitle}"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#222222" />

                <TextBlock Grid.Row="1"
                           Margin="0,24,0,8"
                           Text="Модель"
                           Foreground="#5D6472" />
                <StackPanel Grid.Row="2">
                    <TextBox x:Name="txtModel"
                             Padding="10,8"
                             Text="{Binding Model, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                    <TextBlock Margin="2,6,0,0"
                               Text="{Binding ModelDigitsOnlyHintText}"
                               Foreground="#7A1E2B"
                               FontSize="12.5"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Visibility="{Binding ModelDigitsOnlyHintVisibility}" />
                </StackPanel>

                <Grid Grid.Row="3" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Margin="0,0,0,8"
                                   Text="Техническое состояние"
                                   Foreground="#5D6472" />
                        <ComboBox ItemsSource="{Binding Conditions}"
                                  DisplayMemberPath="ConditionName"
                                  SelectedValuePath="ConditionId"
                                  SelectedValue="{Binding SelectedConditionId, ValidatesOnNotifyDataErrors=True}"
                                  Padding="8,6" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Margin="0,0,0,8"
                                   Text="Оперативный статус"
                                   Foreground="#5D6472" />
                        <ComboBox ItemsSource="{Binding AvailableStatuses}"
                                  SelectedItem="{Binding SelectedStatus, ValidatesOnNotifyDataErrors=True}"
                                  Padding="8,6" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="4" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Margin="0,0,0,8"
                                   Text="Заряд (%)"
                                   Foreground="#5D6472" />
                        <TextBox Padding="10,8"
                                 Text="{Binding BatteryPercentText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Margin="0,0,0,8"
                                   Text="Год выпуска"
                                   Foreground="#5D6472" />
                        <DatePicker SelectedDate="{Binding YearOfRelease, ValidatesOnNotifyDataErrors=True}"
                                    IsEnabled="{Binding IsYearOfReleaseEditable}"
                                    SelectedDateFormat="Short"
                                    Padding="8,4" />
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="5"
                           Margin="0,18,0,8"
                           Text="Местоположение"
                           Foreground="#5D6472" />
                <StackPanel Grid.Row="6">
                    <TextBox Padding="10,8"
                             Text="{Binding CurrentLocation, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                    <TextBlock Margin="2,6,0,0"
                               Text="{Binding LocationDigitsOnlyHintText}"
                               Foreground="#7A1E2B"
                               FontSize="12.5"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Visibility="{Binding LocationDigitsOnlyHintVisibility}" />
                </StackPanel>

                <StackPanel Grid.Row="8"
                            Margin="0,22,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Width="100"
                            Margin="0,0,10,0"
                            Padding="12,8"
                            Click="CancelButton_Click"
                            Content="Отмена" />
                    <Button Width="140"
                            Padding="14,8"
                            Background="#0F1020"
                            Foreground="White"
                            BorderThickness="0"
                            IsEnabled="{Binding CanSave}"
                            Click="SaveButton_Click"
                            Content="Сохранить" />
                </StackPanel>
            </Grid>
        </md:Card>
    </Grid>
</Window>
