<UserControl x:Class="WpfMaterialControls.RidesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    d:DesignHeight="700"
    d:DesignWidth="1100">
    <Border Background="#F8F8FA" Padding="18">
        <Border.Resources>
            <Style x:Key="RidesSummaryCardStyle" TargetType="Border">
                <Setter Property="Background" Value="White" />
                <Setter Property="BorderBrush" Value="#ECECF3" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="Padding" Value="22,18" />
            </Style>

            <Style x:Key="RidesColumnHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Background" Value="#F2F2F7" />
                <Setter Property="BorderBrush" Value="#F2F2F7" />
                <Setter Property="Foreground" Value="#262A33" />
                <Setter Property="Padding" Value="16,14" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="RidesCenteredColumnHeaderStyle"
                   TargetType="DataGridColumnHeader"
                   BasedOn="{StaticResource RidesColumnHeaderStyle}">
                <Setter Property="HorizontalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="RidesFilterComboItemStyle" TargetType="ComboBoxItem">
                <Setter Property="Foreground" Value="#1C1C1C" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="Padding" Value="18,11" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="ItemBorder"
                                    Margin="5,3"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#EFEFEF" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#E8E8E8" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="RidesFilterComboStyle" TargetType="ComboBox">
                <Setter Property="Height" Value="50" />
                <Setter Property="Padding" Value="24,0,42,0" />
                <Setter Property="Background" Value="#F4F4F4" />
                <Setter Property="BorderBrush" Value="#D2D2D2" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="#111111" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="ItemContainerStyle" Value="{StaticResource RidesFilterComboItemStyle}" />
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <ToggleButton x:Name="FilterToggleButton"
                                              Focusable="False"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              ClickMode="Press"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Border x:Name="FilterBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="15">
                                        <Grid>
                                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                              Content="{TemplateBinding SelectionBoxItem}"
                                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                              RecognizesAccessKey="True" />
                                            <Path Width="10"
                                                  Height="6"
                                                  Margin="0,0,18,0"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  Data="M1,1 L5,5 L9,1"
                                                  Stroke="#111111"
                                                  StrokeThickness="1.6"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" />
                                        </Grid>
                                    </Border>
                                </ToggleButton>

                                <Popup x:Name="Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom"
                                       PopupAnimation="Slide">
                                    <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                          MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <Border Margin="0,6,0,0"
                                                Background="White"
                                                BorderBrush="#D2D2D2"
                                                BorderThickness="1"
                                                CornerRadius="15">
                                            <ScrollViewer Margin="0,5"
                                                          SnapsToDevicePixels="True">
                                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsDropDownOpen" Value="True">
                                    <Setter TargetName="FilterBorder" Property="BorderBrush" Value="#C8C8C8" />
                                </Trigger>
                                <Trigger Property="HasItems" Value="False">
                                    <Setter TargetName="Popup" Property="MinHeight" Value="0" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Border.Resources>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="Управление поездками"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#222222"
                       VerticalAlignment="Center" />

            <Grid Grid.Row="1" Margin="0,22,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,12,0" Style="{StaticResource RidesSummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Поездок сегодня" Foreground="#9BA3AF" FontSize="13.5" />
                        <TextBlock Text="{Binding RidesToday}" FontSize="33" FontWeight="SemiBold" Margin="0,10,0,0" Foreground="#1F2430" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Margin="0,0,12,0" Style="{StaticResource RidesSummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="За эту неделю" Foreground="#9BA3AF" FontSize="13.5" />
                        <TextBlock Text="{Binding RidesThisWeek}" FontSize="33" FontWeight="SemiBold" Margin="0,10,0,0" Foreground="#1F2430" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Margin="0,0,12,0" Style="{StaticResource RidesSummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Доход сегодня" Foreground="#9BA3AF" FontSize="13.5" />
                        <TextBlock Text="{Binding RevenueToday}" FontSize="33" FontWeight="SemiBold" Margin="0,10,0,0" Foreground="#1F2430" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource RidesSummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Средняя длительность" Foreground="#9BA3AF" FontSize="13.5" />
                        <TextBlock Text="{Binding AverageDuration}" FontSize="33" FontWeight="SemiBold" Margin="0,10,0,0" Foreground="#1F2430" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Background="White"
                    BorderBrush="#ECECF3"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="18,14,18,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Недавние поездки"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#222222"
                                   VerticalAlignment="Center" />

                        <ComboBox Grid.Column="1"
                                  Width="205"
                                  Margin="0,0,10,0"
                                  Style="{StaticResource RidesFilterComboStyle}"
                                  ItemsSource="{Binding StatusOptions}"
                                  SelectedItem="{Binding SelectedStatus}"
                                  VerticalAlignment="Center" />

                        <ComboBox Grid.Column="3"
                                  Width="175"
                                  Style="{StaticResource RidesFilterComboStyle}"
                                  ItemsSource="{Binding PeriodOptions}"
                                  SelectedItem="{Binding SelectedPeriod}"
                                  VerticalAlignment="Center" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <DataGrid x:Name="RidesDataGrid"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  IsReadOnly="True"
                                  RowHeight="78"
                                  GridLinesVisibility="Horizontal"
                                  ItemsSource="{Binding FilteredItems}"
                                  Background="White"
                                  BorderThickness="0"
                                  RowHeaderWidth="0"
                                  BorderBrush="#ECECF3"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Hidden">
                            <DataGrid.ColumnHeaderStyle>
                                <StaticResource ResourceKey="RidesColumnHeaderStyle" />
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White" />
                                    <Setter Property="BorderBrush" Value="#F0F1F5" />
                                    <Setter Property="Foreground" Value="#2A2F39" />
                                    <Setter Property="SnapsToDevicePixels" Value="True" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F8FAFF" />
                                            <Setter Property="BorderBrush" Value="#DDE7FF" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#F4F7FF" />
                                            <Setter Property="BorderBrush" Value="#D4E1FF" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="16,6" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="#2A2F39" />
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding RideIdText}" Width="0.55*" />

                                <DataGridTemplateColumn Header="Пользователь" Width="1.6*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Viewbox Width="16"
                                                         Height="16"
                                                         Margin="0,0,10,0"
                                                         VerticalAlignment="Center">
                                                    <Canvas Width="16" Height="16">
                                                        <Ellipse Width="5"
                                                                 Height="5"
                                                                 Canvas.Left="5.5"
                                                                 Canvas.Top="1.3"
                                                                 Stroke="#7B8190"
                                                                 StrokeThickness="1.3" />
                                                        <Path Data="M2.4,14.2 C2.8,10.8 5.3,9.2 8,9.2 C10.7,9.2 13.2,10.8 13.6,14.2"
                                                              Stroke="#7B8190"
                                                              StrokeThickness="1.3"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round" />
                                                    </Canvas>
                                                </Viewbox>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding UserPrimaryLine}"
                                                               Foreground="#2A2F39"
                                                               FontSize="13.5"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding UserSecondaryLine}"
                                                               Foreground="#2A2F39"
                                                               FontSize="13.5"
                                                               Margin="0,2,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <Trigger Property="Text" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Самокат" Width="0.95*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Viewbox Width="18"
                                                         Height="18"
                                                         Margin="0,0,10,0"
                                                         VerticalAlignment="Center">
                                                    <Canvas Width="18" Height="18">
                                                        <Ellipse Width="3.2" Height="3.2" Canvas.Left="3.1" Canvas.Top="11.2" Stroke="#7B8190" StrokeThickness="1.2" />
                                                        <Ellipse Width="3.2" Height="3.2" Canvas.Left="11.7" Canvas.Top="11.2" Stroke="#7B8190" StrokeThickness="1.2" />
                                                        <Path Data="M4.8,12 L7.2,7.3 L10.5,7.3 L12.8,12"
                                                              Stroke="#7B8190"
                                                              StrokeThickness="1.2"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round" />
                                                        <Line X1="7.2" Y1="7.3" X2="6" Y2="5.2" Stroke="#7B8190" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                        <Line X1="10.5" Y1="7.3" X2="11.7" Y2="5.2" Stroke="#7B8190" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock Text="{Binding ScooterText}"
                                                           Foreground="#2A2F39"
                                                           FontSize="13.5"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Время" Width="1.15*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StartTime, StringFormat={}{0:dd.MM.yyyy}}"
                                                           Foreground="#2A2F39"
                                                           FontSize="13"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding StartTime, StringFormat={}{0:HH:mm}}"
                                                           Margin="0,0,8,0"
                                                           Foreground="#9BA3AF"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Длительность"
                                                        Width="1.15*"
                                                        HeaderStyle="{StaticResource RidesCenteredColumnHeaderStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid HorizontalAlignment="Stretch">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <Viewbox Width="16"
                                                             Height="16"
                                                             Margin="0,0,8,0"
                                                             VerticalAlignment="Center">
                                                        <Canvas Width="16" Height="16">
                                                            <Ellipse Width="11.5"
                                                                     Height="11.5"
                                                                     Canvas.Left="2.25"
                                                                     Canvas.Top="2.25"
                                                                     Stroke="#8A90A0"
                                                                     StrokeThickness="1.3" />
                                                            <Line X1="8" Y1="8" X2="8" Y2="5.2"
                                                                  Stroke="#8A90A0"
                                                                  StrokeThickness="1.3"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round" />
                                                            <Line X1="8" Y1="8" X2="10.4" Y2="9.4"
                                                                  Stroke="#8A90A0"
                                                                  StrokeThickness="1.3"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round" />
                                                        </Canvas>
                                                    </Viewbox>
                                                    <TextBlock Text="{Binding DurationText}"
                                                               Foreground="#2A2F39"
                                                               FontSize="13.5"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Расстояние"
                                                        Width="1.05*"
                                                        HeaderStyle="{StaticResource RidesCenteredColumnHeaderStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid HorizontalAlignment="Stretch">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <Viewbox Width="16"
                                                             Height="16"
                                                             Margin="0,0,8,0"
                                                             VerticalAlignment="Center">
                                                        <Canvas Width="16" Height="16">
                                                            <Path Data="M8,2.2 C5.4,2.2 3.6,4.1 3.6,6.5 C3.6,9.4 7,12.6 8,13.6 C9,12.6 12.4,9.4 12.4,6.5 C12.4,4.1 10.6,2.2 8,2.2 Z"
                                                                  Stroke="#8A90A0"
                                                                  StrokeThickness="1.2"
                                                                  Fill="Transparent" />
                                                            <Ellipse Width="2.2"
                                                                     Height="2.2"
                                                                     Canvas.Left="6.9"
                                                                     Canvas.Top="5.4"
                                                                     Fill="#8A90A0" />
                                                        </Canvas>
                                                    </Viewbox>
                                                    <TextBlock Text="{Binding DistanceText}"
                                                               Foreground="#2A2F39"
                                                               FontSize="13.5"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Маршрут"
                                                        Width="1.9*"
                                                        HeaderStyle="{StaticResource RidesCenteredColumnHeaderStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid HorizontalAlignment="Stretch">
                                                <TextBlock Text="{Binding RouteText}"
                                                           Foreground="#2A2F39"
                                                           FontSize="13.5"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           MaxWidth="200"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Стоимость"
                                                        Width="0.95*"
                                                        HeaderStyle="{StaticResource RidesCenteredColumnHeaderStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid HorizontalAlignment="Stretch">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="$"
                                                               Margin="0,0,8,0"
                                                               Foreground="#8A90A0"
                                                               FontSize="15"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding CostText}"
                                                               Foreground="#2A2F39"
                                                               FontSize="13.5"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Статус" Width="1*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding StatusBackground}"
                                                    CornerRadius="14"
                                                    Padding="14,6"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusText}"
                                                           Foreground="{Binding StatusForeground}"
                                                           FontSize="12"
                                                           FontWeight="Medium" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Background="#FFFFFF"
                                IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=RidesDataGrid, Path=HasItems}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="Нет поездок для выбранного фильтра"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#555C6A"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Попробуй выбрать период &quot;Все время&quot; или другой статус."
                                           Margin="0,8,0,0"
                                           Foreground="#9BA3AF"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
