<Window x:Class="WpfMaterialControls.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчёты"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="#F8F8FA">
    <Border Padding="18">
        <Border.Resources>
            <Style x:Key="ReportsFilterComboStyle" TargetType="ComboBox">
                <Setter Property="Height" Value="48" />
                <Setter Property="Padding" Value="24,0,42,0" />
                <Setter Property="Background" Value="#F4F4F4" />
                <Setter Property="BorderBrush" Value="#D2D2D2" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="#111111" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="48" />
                <Setter Property="Padding" Value="18,0" />
                <Setter Property="Background" Value="#0F1020" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Cursor" Value="Hand" />
            </Style>
        </Border.Resources>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="Отчёты"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#222222"
                       VerticalAlignment="Center" />

            <Border Grid.Row="1"
                    Margin="0,18,0,18"
                    Background="White"
                    BorderBrush="#ECECF3"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Отчёт по поездкам"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#222222" />
                        <TextBlock Text="Фильтры и экспорт в Excel"
                                   Margin="0,4,0,0"
                                   Foreground="#9BA3AF" />
                    </StackPanel>

                    <ComboBox Grid.Column="1"
                              Width="205"
                              Margin="0,0,0,0"
                              Style="{StaticResource ReportsFilterComboStyle}"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}"
                              VerticalAlignment="Center" />

                    <ComboBox Grid.Column="3"
                              Width="175"
                              Style="{StaticResource ReportsFilterComboStyle}"
                              ItemsSource="{Binding PeriodOptions}"
                              SelectedItem="{Binding SelectedPeriod}"
                              VerticalAlignment="Center" />

                    <Button Grid.Column="5"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding ExportExcelCommand}"
                            Content="Экспорт в Excel"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="White"
                    BorderBrush="#ECECF3"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="0">
                <DataGrid AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          IsReadOnly="True"
                          RowHeight="54"
                          GridLinesVisibility="Horizontal"
                          ItemsSource="{Binding FilteredItems}"
                          Background="White"
                          BorderThickness="0"
                          RowHeaderWidth="0"
                          BorderBrush="#ECECF3"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="FontSize" Value="13" />
                            <Setter Property="Background" Value="#F2F2F7" />
                            <Setter Property="BorderBrush" Value="#F2F2F7" />
                            <Setter Property="Foreground" Value="#262A33" />
                            <Setter Property="Padding" Value="16,14" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="16,6" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="#2A2F39" />
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding RideIdText}" Width="0.55*" />
                        <DataGridTextColumn Header="Пользователь" Binding="{Binding UserName}" Width="1.6*" />
                        <DataGridTextColumn Header="Самокат" Binding="{Binding ScooterText}" Width="0.95*" />
                        <DataGridTextColumn Header="Дата" Binding="{Binding StartTime, StringFormat={}{0:dd.MM.yyyy}}" Width="1.05*" />
                        <DataGridTextColumn Header="Время" Binding="{Binding StartTime, StringFormat={}{0:HH:mm}}" Width="0.8*" />
                        <DataGridTextColumn Header="Длительность" Binding="{Binding DurationText}" Width="1.0*" />
                        <DataGridTextColumn Header="Расстояние" Binding="{Binding DistanceText}" Width="1.0*" />
                        <DataGridTextColumn Header="Маршрут" Binding="{Binding RouteText}" Width="1.9*" />
                        <DataGridTextColumn Header="Стоимость" Binding="{Binding CostText}" Width="1.0*" />
                        <DataGridTextColumn Header="Статус" Binding="{Binding StatusText}" Width="1.0*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Border>
</Window>

