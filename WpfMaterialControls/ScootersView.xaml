<UserControl x:Class="WpfMaterialControls.ScootersView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    mc:Ignorable="d"
    d:DesignHeight="700"
    d:DesignWidth="1100">
    <Border Background="#F8F8FA" Padding="18">
        <Border.Resources>
            <Style x:Key="SummaryCardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="White" />
                <Setter Property="BorderBrush" Value="#ECECF3" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="Padding" Value="18" />
            </Style>

            <Style x:Key="RoundedPrimaryButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Background" Value="#0F1020" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="18,10" />
                <Setter Property="MinWidth" Value="185" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="12">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Border.Resources>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Управление самокатами"
                       FontSize="23"
                       FontWeight="SemiBold"
                       Foreground="#1F2430"
                       VerticalAlignment="Center" />

            <Button Grid.Column="1"
                    Style="{StaticResource RoundedPrimaryButtonStyle}"
                    Command="{Binding AddCommand}"
                    Content="+  Добавить самокат" />

            <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,16,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,12,0" Style="{StaticResource SummaryCardBorderStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Всего самокатов" Foreground="#98A0AF" FontSize="13.5" />
                        <TextBlock Text="{Binding TotalCount}" Margin="0,11,0,0" FontSize="33" FontWeight="SemiBold" Foreground="#1F2430" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Margin="0,0,12,0" Style="{StaticResource SummaryCardBorderStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Доступно" Foreground="#98A0AF" FontSize="13.5" />
                        <TextBlock Text="{Binding AvailableCount}" Margin="0,11,0,0" FontSize="33" FontWeight="SemiBold" Foreground="#2EA35F" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource SummaryCardBorderStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Требуют внимания" Foreground="#98A0AF" FontSize="13.5" />
                        <TextBlock Text="{Binding AttentionCount}" Margin="0,11,0,0" FontSize="33" FontWeight="SemiBold" Foreground="#C39917" />
                    </StackPanel>
                </Border>
            </Grid>

            <md:Card Grid.Row="2" Grid.ColumnSpan="2" Padding="0" Margin="0,0,0,14">
                <DataGrid x:Name="dgScooters"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          IsReadOnly="True"
                          RowHeight="56"
                          GridLinesVisibility="Horizontal"
                          ItemsSource="{Binding Items}"
                          Background="White"
                          BorderThickness="0"
                          RowHeaderWidth="0"
                          BorderBrush="#ECECF3"
                          HorizontalScrollBarVisibility="Disabled">
                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#F8F9FD" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#F8F9FD" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F8F9FD" />
                    </DataGrid.Resources>

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="FontSize" Value="13" />
                            <Setter Property="Background" Value="#F2F2F7" />
                            <Setter Property="BorderBrush" Value="#F2F2F7" />
                            <Setter Property="Foreground" Value="#262A33" />
                            <Setter Property="Padding" Value="12,11" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="BorderBrush" Value="#F0F1F5" />
                            <Setter Property="Foreground" Value="#2A2F39" />
                            <Setter Property="SnapsToDevicePixels" Value="True" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridRow">
                                        <Border x:Name="RowBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="0,0,0,1">
                                            <SelectiveScrollingGrid>
                                                <SelectiveScrollingGrid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </SelectiveScrollingGrid.ColumnDefinitions>
                                                <SelectiveScrollingGrid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </SelectiveScrollingGrid.RowDefinitions>
                                                <DataGridCellsPresenter Grid.Column="1"
                                                                        ItemsPanel="{TemplateBinding ItemsPanel}"
                                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                <DataGridDetailsPresenter Grid.Column="1"
                                                                          Grid.Row="1"
                                                                          Visibility="{TemplateBinding DetailsVisibility}" />
                                            </SelectiveScrollingGrid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="RowBorder" Property="Background" Value="#F6F7FB" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="RowBorder" Property="Background" Value="#F2F4FA" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="12,6" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding DisplayId}" Width="0.9*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="TextAlignment" Value="Left" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Статус" Width="1.45*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding StatusBackground}"
                                            CornerRadius="13"
                                            Padding="12,5"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="{Binding StatusForeground}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Medium" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Заряд" Width="0.95*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,0">
                                        <TextBlock Text="{Binding ChargeIcon}"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding ChargeColor}" />
                                        <TextBlock Text="{Binding ChargeText}"
                                                   Margin="7,0,0,0"
                                                   Foreground="#303540"
                                                   FontSize="12.5" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Местоположение" Binding="{Binding Location}" Width="2.25*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="TextAlignment" Value="Left" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Последняя поездка" Binding="{Binding LastRide}" Width="1.55*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="TextAlignment" Value="Left" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Действия" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Button Width="28"
                                                Height="28"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                Foreground="#343948"
                                                Cursor="Hand"
                                                ToolTip="Редактировать"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding Id}"
                                                Content="✎" />
                                        <Button Width="28"
                                                Height="28"
                                                Margin="6,0,0,0"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                Foreground="#D15B75"
                                                Cursor="Hand"
                                                ToolTip="Удалить"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding Id}"
                                                Content="⌫" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </md:Card>

            <md:Card Grid.Row="3" Grid.ColumnSpan="2" Padding="14" Background="#FFF9E8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠"
                               FontSize="18"
                               Foreground="#C39917"
                               Margin="0,0,12,0" />
                    <StackPanel>
                        <TextBlock Text="Требуется внимание"
                                   FontWeight="SemiBold"
                                   Foreground="#7B6124" />
                        <TextBlock Text="{Binding WarningText}"
                                   Margin="0,4,0,0"
                                   Foreground="#8E7240"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </md:Card>
        </Grid>
    </Border>
</UserControl>